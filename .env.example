# GitHub
GITHUB_SECRET=
GITHUB_USERNAME=
GITHUB_REPO=
EXCLUDED_GITHUB_FILES=

# Telegram
TELEGRAM_BOT_TOKEN=
CHAT_ID=
TELEGRAM_TOPIC_THM=
TELEGRAM_TOPIC_NEWS=
TELEGRAM_TOPIC_YOUTUBE=
TELEGRAM_TOPIC_PODCAST=
TELEGRAM_TOPIC_GITHUB=
TELEGRAM_TOPIC_REDDIT=
TELEGRAM_TOPIC_CVE=

# AI Provider
AI_PROVIDER=mistral                        # mistral (default) or claude
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-2411           # optional, default: mistral-large-2411
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-20250514        # optional, default: claude-opus-4-20250514

# YouTube
YOUTUBE_API_KEY=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_SUBREDDITS=netsec,cybersecurity,securityCTF,blackhat,HowToHack  # optional, default list
REDDIT_DAYS_LOOKBACK=3                     # optional, default: 3

# CVE (sendCve)
CVSS_SEVERITY_THRESHOLD=7.0               # optional, default: 7.0
HOURS_DELAY=24                            # optional, default: 24
ENABLE_CVE_STATS=false                    # optional, default: false
TOP_CVES_COUNT=5                          # optional, default: 5

# News Resume (sendNewsResume)
NEWS_DAYS_TO_FETCH=3                      # optional, default: 3
NEWS_ARTICLES_TO_SEND=1                   # optional, default: 1
NEWS_DELAY_BETWEEN_ARTICLES=10000         # optional, in ms, default: 10000

# Shared content processing
MAX_RELEVANCE_CHECKS=5                    # optional, used by news & reddit, default: 5

# YouTube Shorts (sendShort)
SHORTS_DAYS_AGO=30                        # optional, default: 30

# Database (optional)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=3306
MYSQL_DATABASE=
TELEGRAM_TABLE_NAME=TelegramLogs
I_WANT_TO_SAVE_MESSAGES_IN_DB=false

# AssemblyAI (podcasts)
ASSEMBLYAI_API_KEY=

# Supadata
SUPADATA_KEY=

# Slack logging (optional)
SLACK_LOGGING_ENABLED=false
SLACK_WEBHOOK_URL_INFO=
SLACK_WEBHOOK_URL_WARN=
SLACK_WEBHOOK_URL_ERROR=

# Logging
LOG_LEVEL=info                            # optional, default: info
